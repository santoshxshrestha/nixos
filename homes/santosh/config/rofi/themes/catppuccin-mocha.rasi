configuration {
    modi: "drun,window,run,ssh";
    show-icons: true;
    terminal: "kitty";
    icon-theme: "Papirus";
    drun-display-format: "{icon} {name}";
    // https://davatorium.github.io/rofi/guides/Positioning/theme3-position
    location: 0;
    disable-history: true;
    hide-scrollbar: false;
    display-drun: " Apps ";
    display-run: " Run ";
    display-window: " Window ";
    sidebar-mode: true;
    kb-row-up: "Up,Control+p";
    kb-row-down: "Down,Control+n";
    kb-accept-entry: "Return,KP_Enter";

    kb-mode-complete: "";
    kb-clear-line: "";

    kb-mode-next: "Control+l";

    kb-mode-previous: "Ctrl+h";
    kb-remove-char-back: "BackSpace";
    kb-remove-word-back: "Control+w,Control+BackSpace";
}

* {
    font: "JetBrainsMono Nerd Font 10";

    /* Catppuccin Mocha Colors */
    base:        #000000cc;   /* 80% opacity */
    mantle:      #181818cc;   /* near black */
    crust:       #111111cc;   /* darker */
    surface0:    #222222cc;   /* dark gray */
    surface1:    #2f2f2fcc;   /* mid gray */
    surface2:    #606060cc;   /* light gray border */
    overlay1:    #7f7f7fcc;   /* overlay text gray */
    overlay2:    #969696cc;   /* lighter overlay */
    blue:        #444444cc;   /* dark gray accent, replaces blue */
    lavender:    #606060cc;     /* gray accent, replaces lavender */
    sky:         #89dceb;     /* accent sky */
    red:         #f38ba8;     /* accent red */
    mantle:      #181818cc;
    text:        #ffffff;
    background-color: @base;
    border-color: @surface2;
    text-color: #ffffff;
}

window {
    width: 22%;
    height: 47%;
    transparency: "real";
    blur: true;
    background-color: @base;
    border: 2px;
    border-color: @surface2;
    border-radius: 18px;
    padding: 8px;
}

mainbox {
    children: [inputbar, message, listview, mode-switcher];
    background-color: transparent;
    spacing: 8px;
    padding: 8px;
}

inputbar {
    children: [prompt, entry];
    background-color: @surface1;
    border-radius: 14px;
    padding: 8px;
    border: 1px;
    border-color: @surface2;
}

prompt {
    background-color: transparent;
    padding: 0 14px 0 0;
    text-color: #ffffff;
    font: "JetBrainsMono Nerd Font Bold 11";
}

entry {
    background-color: transparent;
    placeholder: "search...";
    placeholder-color: #ffffff;
    padding: 0;
}

message {
    border-radius: 14px;
    padding: 4px;
    background-color: @surface0;
    margin: 0 6px;
}

textbox {
    padding: 4px;
    text-color: #ffffff;
}

listview {
    lines: 12;
    columns: 1;
    fixed-height: false;
    dynamic: true;
    scrollbar: true;
    background-color: transparent;
    border-radius: 14px;
    margin: 0 6px;
    spacing: 6px;
}

scrollbar {
    width: 1px;
    border-radius: 4px;
    background-color: @surface1;
    handle-color: @blue;
    handle-width: 2px;
    padding: 0;
}

element {
    padding: 6px;
    margin: 3px 0;
    border-radius: 12px;
    spacing: 6px;
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
    text-color: #ffffff;
}

element selected.normal {
    background-color: @blue;
    text-color: #ffffff;
    border: 1px;
    border-color: @lavender;
    border-radius: 12px;
}

element-icon {
    size: 18px;
    padding: 0 8px 0 14px;
    background-color: transparent;
}

element-text {
    background-color: transparent;
    text-color: #ffffff;
}

element-text selected, element.selected.normal element-text {
    background-color: #444444cc;
    text-color: #ffffff;
    border-radius: 8px;
    padding-left: 8px;
    padding-right: 8px;
}

element-text {
    background-color: transparent;
    text-color: #ffffff;
    vertical-align: 0.5;
    highlight: none;
}

mode-switcher {
    margin: 6px;
    spacing: 10px;
}

button {
    text-color: #ffffff;
    border-radius: 12px;
    background-color: @surface2;
    padding: 6px 8px;
    horizontal-align: 0.5;
    border: 1px;
    border-color: transparent;
}

button selected {
    background-color: @blue;
    text-color: #ffffff;
    border-color: @lavender;
}

error-message {
    background-color: @red;
    text-color: #ffffff;
    border-radius: 12px;
    padding: 12px;
}

num-filtered-rows, num-rows {
    text-color: #ffffff;
    expand: false;
}

case-indicator {
    text-color: #ffffff;
    background-color: transparent;
}

element-text selected {
    text-color: #ffffff;
}

element {
    children: [element-icon, element-text];
}

element-icon selected {
    background-color: transparent;
}

element.active,
element.selected.active {
    background-color: @sky;
    text-color: #ffffff;
}

element.selected.active {
    background-color: @blue;
    border-color: @sky;
}

element.urgent,
element.selected.urgent {
    background-color: @red;
    text-color: #ffffff;
}

element.selected.urgent {
    background-color: @blue;
    border-color: @red;
}
