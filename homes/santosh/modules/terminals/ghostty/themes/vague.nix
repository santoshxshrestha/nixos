    "3=#f3be7c"
    "4=#6e94b2"
    "5=#bb9dbd"
    "6=#aeaed1"
    "7=#cdcdcd"

    # bright
    "8=#606079"
    "9=#e08398"
    "10=#99b782"
    "11=#f5cb96"
    "12=#8ba9c1"
    "13=#c9b1ca"
    "14=#bebeda"
    "15=#d7d7d7"
